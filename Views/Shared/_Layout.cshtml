@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>V.I.P-Planning</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #050505; color: #fff; font-family: 'Segoe UI', sans-serif; margin: 0; }
        .sidebar { height: 100vh; width: 250px; position: fixed; top: 0; left: 0; background: #0a0a0a; border-right: 1px solid #D4AF37; padding: 20px; z-index: 1000; }
        .main-content { margin-left: 250px; padding: 40px; min-height: 100vh; background: radial-gradient(circle at top right, #111 0%, #050505 100%); }
        .nav-link-vip { color: #888; text-decoration: none; display: block; padding: 12px 15px; border-radius: 10px; margin-bottom: 5px; transition: 0.3s; font-weight: 600; font-size: 0.9rem; }
        .nav-link-vip:hover { background: rgba(212, 175, 55, 0.1); color: #D4AF37; }
        .nav-link-vip.active { background: rgba(212, 175, 55, 0.15); color: #D4AF37; border-left: 3px solid #D4AF37; }
        .vip-logo { font-weight: 900; font-size: 1.4rem; letter-spacing: 2px; background: linear-gradient(to right, #D4AF37, #F1E2A1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 40px; display: block; text-decoration: none; }
    </style>
</head>
<body>
    @if (HttpContextAccessor.HttpContext.Session.GetString("IsLoggedIn") == "true")
    {
        <div class="sidebar">
            <a href="/" class="vip-logo">V.I.P-Planning</a>
            
            <a href="/Home/Index" class="nav-link-vip">🏠 DASHBOARD</a>
            
            <a href="/Home/Planning" class="nav-link-vip">📅 PLANNING & PUSH</a>
            
            <a href="/Home/Werknemers" class="nav-link-vip">👥 MEDEWERKERS</a>
            
            <a href="/Home/Instellingen" class="nav-link-vip">⚙️ INSTELLINGEN</a>

            <div style="position:absolute; bottom: 20px; width: 210px;">
                <hr style="border-color: #333;">
                <a href="/Account/Logout" class="nav-link-vip" style="color: #ff4d4d;">❌ UITLOGGEN</a>
            </div>
        </div>
        <div class="main-content">
            @RenderBody()
        </div>
    }
    else
    {
        <div class="container mt-5">
            @RenderBody()
        </div>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>