<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>VIP Planning</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #000 !important; color: #fff !important; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 0; }
        .sidebar { background-color: #000; border-right: 2px solid #D4AF37; height: 100vh; position: fixed; width: 250px; z-index: 1000; }
        .main-content { margin-left: 250px; padding: 20px; }
        @media (max-width: 991px) {
            .sidebar { position: relative !important; width: 100% !important; height: auto !important; border-right: none !important; border-bottom: 2px solid #D4AF37 !important; padding: 10px 0 !important; }
            .main-content { margin-left: 0 !important; padding: 15px !important; }
            .nav { flex-direction: row !important; justify-content: space-around !important; }
        }
        .nav-link { color: #D4AF37 !important; font-weight: bold; text-decoration: none; padding: 10px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <a class="navbar-brand text-center d-block" href="/Home/Index" style="color:#D4AF37; font-weight:900; text-decoration:none; font-size: 1.5rem;">V.I.P SECURITY</a>
        <nav class="nav flex-column flex-md-row justify-content-center">
            <a class="nav-link" href="/Home/Index">🏠</a>
            <a class="nav-link" href="/Home/Planning">📅</a>
            <a class="nav-link" href="/Home/Werknemers">👥</a>
            <a class="nav-link" href="/Home/Instellingen">⚙️</a>
            <a class="nav-link text-danger" href="/Account/Logout">🚪</a>
        </nav>
    </div>
    <div class="main-content">
        <div class="table-responsive">
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>