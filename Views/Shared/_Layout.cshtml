<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>VIP Planning</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #000; color: #fff; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
        
        /* Sidebar voor Desktop */
        .sidebar { 
            background-color: #000; 
            border-right: 2px solid #D4AF37; 
            height: 100vh; 
            position: fixed; 
            width: 250px; 
            padding-top: 20px; 
            z-index: 1000;
        }

        /* Hoofdinhoud */
        .main-content { margin-left: 250px; padding: 20px; transition: 0.3s; }

        .nav-link { color: #D4AF37 !important; font-weight: bold; text-transform: uppercase; padding: 12px 25px; border-bottom: 1px solid #1a1a1a; }
        .nav-link:hover { background-color: #D4AF37; color: #000 !important; }

        /* MOBIELE AANPASSINGEN */
        @media (max-width: 992px) {
            .sidebar { 
                width: 100%; 
                height: auto; 
                position: relative; 
                border-right: none; 
                border-bottom: 2px solid #D4AF37; 
                padding-bottom: 10px;
            }
            .main-content { margin-left: 0; padding: 10px; }
            .nav-link { display: inline-block; padding: 10px 15px; border-bottom: none; font-size: 0.8rem; }
            .navbar-brand { margin-bottom: 10px; font-size: 1.2rem; }
            
            /* Maak tabellen scrollbaar op mobiel */
            .table-responsive {
                display: block;
                width: 100%;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            
            /* Tekst iets kleiner op mobiel voor betere fit */
            h1 { font-size: 1.8rem !important; }
            .total-badge { font-size: 1rem !important; padding: 10px !important; }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <a class="navbar-brand text-center d-block" href="/Home/Index" style="color:#D4AF37; font-weight:900; text-decoration:none;">V.I.P SECURITY</a>
        <nav class="nav flex-column flex-md-row justify-content-center">
            <a class="nav-link" href="/Home/Index">🏠 <span class="d-none d-sm-inline">Dashboard</span></a>
            <a class="nav-link" href="/Home/Planning">📅 <span class="d-none d-sm-inline">Planning</span></a>
            <a class="nav-link" href="/Home/Werknemers">👥 <span class="d-none d-sm-inline">Personeel</span></a>
            <a class="nav-link" href="/Home/Instellingen">⚙️ <span class="d-none d-sm-inline">Opties</span></a>
            <a class="nav-link text-danger" href="/Account/Logout">🚪</a>
        </nav>
    </div>
    <div class="main-content">
        <div class="table-responsive">
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>