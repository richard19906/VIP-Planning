@{
    /* De layout zelf heeft geen layout nodig om lussen te voorkomen */
    Layout = null;
}<!DOCTYPE html><html lang="nl"><head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>V.I.P. Planning</title>
    
    <!-- Google Fonts: Cinzel voor VIP titels & Inter voor leesbaarheid -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root { 
            /* Standaardwaarden als er niets in localStorage staat */
            --gold: #D4AF37; 
            --gold-bright: #F9E27D;
            --glow: rgba(212, 175, 55, 0.4); 
        }

        body { 
            background: #000; 
            color: #FFF; 
            font-family: 'Inter', sans-serif; 
            margin: 0; 
            overflow-x: hidden;
            transition: opacity 0.4s ease;
        }

        /* Sidebar Styling */
        .sidebar { 
            width: 280px; 
            height: 100vh; 
            position: fixed; 
            border-right: 1px solid var(--gold); 
            background: #000; 
            display: flex;
            flex-direction: column;
            box-shadow: 10px 0 30px rgba(0,0,0,0.8);
            z-index: 1000;
            transition: border-color 0.5s ease;
        }

        .sidebar-header {
            padding: 50px 20px 30px 20px;
            text-align: center;
        }

        .vip-sidebar-welcome {
            font-family: 'Cinzel', serif;
            font-weight: 900;
            font-size: 2.2rem;
            letter-spacing: 5px;
            background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 15px var(--glow);
            margin: 0;
            transition: 0.5s ease;
        }

        /* Dashboard Titels die meekleuren */
        .vip-header-title-main {
            font-family: 'Cinzel', serif;
            font-weight: 900;
            font-size: 0.8rem;
            letter-spacing: 2px;
            background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 10px var(--glow);
            margin: 0;
            text-transform: uppercase;
            transition: 0.5s ease;
        }

        .vip-subtitle-gold {
            color: var(--gold) !important;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin: 0;
            opacity: 1;
            transition: 0.5s ease;
        }

        .vip-gold-line-main {
            width: 100px;
            height: 2px;
            background: linear-gradient(to right, var(--gold), transparent);
            margin: 5px 0 10px 0;
            box-shadow: 0 0 8px var(--glow);
            transition: 0.5s ease;
        }

        .vip-gold-line-sidebar {
            width: 60px;
            height: 3px;
            background: linear-gradient(to right, transparent, var(--gold), transparent);
            margin: 15px auto;
            box-shadow: 0 0 10px var(--glow);
            transition: 0.5s ease;
        }

        .nav-link { 
            color: rgba(255,255,255,0.6) !important; 
            padding: 15px 30px; 
            font-weight: 700; 
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255,255,255,0.05); 
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
        }

        .nav-link:hover, .nav-link.active { 
            color: var(--gold) !important; 
            background: linear-gradient(90deg, rgba(255,255,255,0.1) 0%, transparent 100%);
            text-shadow: 0 0 10px var(--glow);
            padding-left: 45px;
        }

        .nav-link i { 
            font-size: 1.2rem; 
            margin-right: 15px; 
            color: var(--gold); 
            transition: color 0.5s ease;
        }

        .logout-container { margin-top: auto; padding-bottom: 20px; }
        .nav-link.logout { color: #ff4d4d !important; border-bottom: none; opacity: 0.8; }
        .nav-link.logout:hover { background: rgba(255, 77, 77, 0.1); color: #ff4d4d !important; opacity: 1; padding-left: 40px; }

        .main { 
            margin-left: 280px; 
            padding: 40px; 
            min-height: 100vh; 
            background: radial-gradient(circle at top right, #151515, #000); 
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #000; }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 10px; }

    </style></head><body id="body-main">
    <div class="sidebar">
        <div class="sidebar-header">
            <h1 class="vip-sidebar-welcome" id="header-text">WELKOM</h1>
            <div class="vip-gold-line-sidebar"></div>
        </div>

        <nav class="nav flex-column mt-3">
            @{
                var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
            }
            <a class="nav-link @(currentAction == "Index" ? "active" : "")" href="/Home/Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="nav-link @(currentAction == "Planning" ? "active" : "")" href="/Home/Planning">
                <i class="bi bi-calendar3"></i> Planning
            </a>
            <a class="nav-link @(currentAction == "Werknemers" ? "active" : "")" href="/Home/Werknemers">
                <i class="bi bi-people-fill"></i> Werknemers
            </a>
            <a class="nav-link @(currentAction == "Instellingen" ? "active" : "")" href="/Home/Instellingen">
                <i class="bi bi-gear-fill"></i> Instellingen
            </a>
        </nav>

        <div class="logout-container">
            <a class="nav-link logout" href="/Account/Logout">
                <i class="bi bi-lock-fill"></i> Uitloggen
            </a>
        </div>
    </div>

    <div class="main">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Functie om thema direct toe te passen bij het laden
        function applySavedTheme() {
            const savedGold = localStorage.getItem('vip-gold');
            const savedBright = localStorage.getItem('vip-gold-bright');
            const savedGlow = localStorage.getItem('vip-glow');
            const savedBrightness = localStorage.getItem('vip-brightness');

            if (savedGold) {
                document.documentElement.style.setProperty('--gold', savedGold);
            }
            if (savedBright) {
                document.documentElement.style.setProperty('--gold-bright', savedBright);
            }
            if (savedGlow) {
                document.documentElement.style.setProperty('--glow', savedGlow);
            }
            if (savedBrightness) {
                document.getElementById('body-main').style.opacity = savedBrightness;
            }
        }

        // Voer uit bij laden van DOM
        document.addEventListener("DOMContentLoaded", applySavedTheme);
        
        // Luister ook naar wijzigingen in localStorage (voor als je in een andere tab instellingen aanpast)
        window.addEventListener('storage', applySavedTheme);
    </script></body></html>