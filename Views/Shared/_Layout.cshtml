@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html>
<head>
    <title>VIP Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #000 url('/images/vip-bg.jpg') no-repeat center center fixed; background-size: cover; color: white; margin: 0; font-family: 'Segoe UI', sans-serif; }
        .sidebar { width: 300px; height: 100vh; background: rgba(0,0,0,0.9); border-right: 1px solid #D4AF37; padding: 40px 20px; position: fixed; z-index: 100; }
        .main-view { margin-left: 300px; padding: 60px; background: rgba(0,0,0,0.4); min-height: 100vh; }
        .vip-btn { display: block; padding: 15px; margin-bottom: 15px; border: 1px solid rgba(212,175,55,0.3); color: #D4AF37; text-decoration: none; border-radius: 10px; transition: 0.3s; font-weight: 600; letter-spacing: 1px; }
        .vip-btn:hover { background: rgba(212,175,55,0.2); border-color: #D4AF37; transform: translateX(10px); color: #D4AF37; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2 style="color: #D4AF37; letter-spacing: 5px; font-weight: 800; text-align:center;">VIP PANEEL</h2>
        <hr style="border-color: #D4AF37;">
        <a href="/Home/Index" class="vip-btn">📊 DASHBOARD</a>
        <a href="/Home/Roosters" class="vip-btn">📅 ROOSTERS</a>
        <a href="/Home/Uren" class="vip-btn">⏱️ GEWERKTE UREN</a>
        <a href="/Home/Personeel" class="vip-btn">👥 PERSONEEL</a>
        <a href="/Home/Instellingen" class="vip-btn">⚙️ INSTELLINGEN</a>
        <div style="position: absolute; bottom: 40px; width: 260px;">
            <a href="/Account/Logout" class="vip-btn" style="border-color: #ff4444; color: #ff4444;">❌ UITLOGGEN</a>
        </div>
    </div>
    <div class="main-view">
        @RenderBody()
    </div>
</body>
</html>