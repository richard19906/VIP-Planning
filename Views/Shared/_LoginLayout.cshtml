<!DOCTYPE html>
<html>
<head>
    <title>VIP Toegang</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        body { background: #000 url('/images/vip-bg.jpg') no-repeat center center fixed; background-size: cover; margin: 0; overflow: hidden; font-family: 'Segoe UI', sans-serif; }
        .vault-box { background: rgba(10, 10, 10, 0.95); border-radius: 40px; padding: 60px; width: 450px; border: 2px solid #D4AF37; box-shadow: 0 0 50px rgba(0,0,0,1); position: relative; z-index: 10; }
        .vip-input { background: rgba(255,255,255,0.05); border: 1px solid rgba(212,175,55,0.5); color: #D4AF37; text-align: center; border-radius: 10px; padding: 15px; margin-bottom: 20px; width: 100%; }
        .btn-gold { background: #D4AF37; color: #000; font-weight: 900; border: none; padding: 15px; border-radius: 10px; width: 100%; letter-spacing: 2px; cursor: pointer; }
    </style>
</head>
<body>
    <div id="particles-js" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; z-index: 1;"></div>
    @RenderBody()
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script>
        particlesJS("particles-js", { "particles": { "number": { "value": 60 }, "color": { "value": "#D4AF37" }, "shape": { "type": "circle" }, "opacity": { "value": 0.5 }, "size": { "value": 3 }, "line_linked": { "enable": true, "distance": 150, "color": "#D4AF37", "opacity": 0.2, "width": 1 }, "move": { "enable": true, "speed": 2 } } });
    </script>
</body>
</html>