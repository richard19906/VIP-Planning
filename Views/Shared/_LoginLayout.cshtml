<!DOCTYPE html>
<html>
<head>
    <title>VIP Toegang</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { 
            background: #000; 
            color: #D4AF37; 
            font-family: 'Segoe UI', sans-serif; 
            margin: 0;
            display: flex; 
            align-items: center; 
            justify-content: center; 
            height: 100vh; 
            overflow: hidden; 
        }
        .vault-box { 
            background: rgba(15, 15, 15, 0.95); 
            border: 2px solid #D4AF37; 
            border-radius: 40px; 
            padding: 50px; 
            width: 420px; 
            box-shadow: 0 0 70px rgba(212, 175, 55, 0.2); 
            text-align: center;
        }
        .vip-input { 
            background: #111; 
            border: 1px solid #D4AF37; 
            color: #D4AF37; 
            border-radius: 10px; 
            padding: 12px; 
            margin-bottom: 15px; 
            width: 100%; 
            text-align: center; 
        }
        .btn-gold { 
            background: #D4AF37; 
            color: #000; 
            font-weight: 900; 
            width: 100%; 
            padding: 15px; 
            border-radius: 10px; 
            border: none; 
            cursor: pointer; 
            transition: 0.3s;
        }
        .btn-gold:hover { background: #fff; }
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>