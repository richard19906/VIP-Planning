@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: url('/images/glitter_bg.png') no-repeat center center fixed; background-size: cover; color: #D4AF37; }
        .card { background: rgba(10,10,10,0.95); border: 2px solid #D4AF37; border-radius: 20px; padding: 40px; width: 400px; box-shadow: 0 0 30px #D4AF37; }
        .form-control { background: rgba(255,255,255,0.05) !important; border: 1px solid #D4AF37 !important; color: #fff !important; }
        .feedback { font-size: 0.8rem; margin-top: -10px; margin-bottom: 15px; font-weight: bold; display: block; }
        .text-ok { color: #28a745 !important; } .text-fail { color: #dc3545 !important; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card">
        <h2 class="text-center mb-4" style="font-weight:900;">VIP REGISTRATIE</h2>
        <form action="/Account/Register" method="post">
            <input type="text" name="naam" class="form-control mb-3" placeholder="Volledige Naam" required />
            <input type="email" name="email" class="form-control mb-3" placeholder="E-mailadres" required />
            <input type="password" id="pw" name="password" class="form-control mb-3" placeholder="Wachtwoord" required />
            <div id="pwF" class="feedback text-fail">Te kort (min. 8)</div>
            <input type="password" id="pwc" name="confirmPassword" class="form-control mb-3" placeholder="Bevestig Wachtwoord" required />
            <div id="matchF" class="feedback text-fail">Matcht niet</div>
            <button type="submit" class="btn w-100" style="background:#D4AF37; color:#000; font-weight:bold;">ONTVAL VERIFICATIECODE</button>
        </form>
    </div>
    <script>
        const pw = document.getElementById('pw'), pwc = document.getElementById('pwc'), pwF = document.getElementById('pwF'), matchF = document.getElementById('matchF');
        pw.addEventListener('input', () => { if(pw.value.length>=8){pwF.innerText='OK';pwF.className='feedback text-ok';}else{pwF.innerText='Te kort';pwF.className='feedback text-fail';} });
        pwc.addEventListener('input', () => { if(pwc.value===pw.value){matchF.innerText='Wachtwoorden matchen';matchF.className='feedback text-ok';}else{matchF.innerText='Matcht niet';matchF.className='feedback text-fail';} });
    </script>
</body>
</html>