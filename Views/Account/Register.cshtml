@{ Layout = null; }
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account Maken - VIP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #000; color: #fff; display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: sans-serif; }
        .card { background: #0f0f0f; border: 2px solid #D4AF37; border-radius: 25px; padding: 35px; width: 100%; max-width: 400px; }
        .btn-gold { background: #D4AF37; color: #000; font-weight: bold; border: none; padding: 12px; border-radius: 12px; }
        .form-control { background: #1a1a1a; border: 1px solid #333; color: #fff; border-radius: 10px; }
    </style>
</head>
<body>
    <div class="card text-center">
        <h2 style="color:#D4AF37; font-weight:900; margin-bottom: 25px;">VIP REGISTRATIE</h2>
        <form method="post">
            <div class="mb-3 text-start">
                <label class="small text-white-50">EMAIL</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <div class="mb-3 text-start">
                <label class="small text-white-50">WACHTWOORD</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            <div class="mb-4 text-start">
                <label class="small text-white-50">BEVESTIG WACHTWOORD</label>
                <input type="password" name="confirmPassword" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-gold w-100">ACCOUNT MAKEN</button>
        </form>
        <div class="mt-3"><a href="/Account/Login" style="color:#888; text-decoration:none;">Terug naar inloggen</a></div>
        @if(ViewBag.Error != null) { <p class="text-danger mt-3 small">@ViewBag.Error</p> }
    </div>
</body>
</html>