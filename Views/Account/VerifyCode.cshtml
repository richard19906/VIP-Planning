@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #000; color: #fff; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: #0f0f0f; border: 2px solid #D4AF37; border-radius: 20px; padding: 30px; width: 100%; max-width: 400px; text-align: center; }
        .code-input { letter-spacing: 15px; font-size: 2rem; text-align: center; background: #1a1a1a; color: #D4AF37; border: 1px solid #333; }
    </style>
</head>
<body>
    <div class="card">
        <h2 style="color:#D4AF37;">CODE VERIFICATIE</h2>
        <p class="small text-white-50">Voer de 6-cijferige code in die naar je mail is gestuurd.</p>
        <form action="/Account/VerifyCode" method="post">
            <input type="hidden" name="email" value="@TempData["Email"]" />
            <div class="mb-4">
                <input type="text" name="code" class="form-control code-input" maxlength="6" placeholder="000000" required />
            </div>
            <button type="submit" class="btn btn-warning w-100 fw-bold" style="background:#D4AF37; color:#000;">VERIFIEER ACCOUNT</button>
        </form>
    </div>
</body>
</html>