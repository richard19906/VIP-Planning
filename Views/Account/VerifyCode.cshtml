@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #D4AF37; --glow: rgba(212, 175, 55, 0.4); }
        body { background: #000; color: #fff; margin:0; font-family: 'JetBrains Mono', monospace; }
        .login-card { background: #0a0a0a; border: 2px solid var(--gold); border-radius: 30px; padding: 40px; width: 100%; max-width: 420px; box-shadow: 0 0 30px var(--glow); }
        h2 { font-family: 'Cinzel', serif; font-weight: 900; color: var(--gold); letter-spacing: 3px; }
        .code-input { letter-spacing: 12px; font-size: 2rem; text-align: center; background: rgba(255,255,255,0.05); color: #ffffff; border: 1px solid var(--gold) !important; }
        .code-input::placeholder { color: rgba(255,255,255,0.2); }
        .btn-gold { background: var(--gold); color: #000; font-weight: 900; border: none; padding: 12px; font-family: 'Cinzel', serif; border-radius: 12px; transition: 0.3s; }
        .btn-gold:hover { background: #f9e27d; transform: scale(1.02); }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="login-card text-center">
        <h2 class="mb-3">BEVESTIG CODE</h2>
        
        @{
            // We halen de email op en zetten hem direct weer terug in TempData 
            // zodat hij beschikbaar blijft bij een onjuiste code-poging.
            var email = TempData["Email"]?.ToString();
            if (email != null) TempData.Keep("Email");
        }

        <p class="small text-white-50 mb-4">
            DE VERIFICATIECODE IS VERSTUURD NAAR:<br />
            <span style="color: var(--gold);">@email</span>
        </p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger bg-transparent border-danger text-danger small mb-3">
                <i class="bi bi-exclamation-circle-fill"></i> @ViewBag.Error
            </div>
        }

        <form action="/Account/VerifyCode" method="post">
            <input type="hidden" name="email" value="@email" />
            <div class="mb-4">
                <input type="text" name="code" class="form-control code-input" maxlength="6" placeholder="000000" autofocus required />
            </div>
            <button type="submit" class="btn btn-gold w-100">VERIFIEER ACCOUNT</button>
        </form>

        <div class="mt-4">
            <a href="/Account/Register" style="color: var(--gold); text-decoration:none; font-size: 0.7rem; opacity: 0.7;">GEEN CODE ONTVANGEN? OPNIEUW REGISTREREN</a>
        </div>
    </div>

    <script>
        const savedGold = localStorage.getItem('vip-gold');
        if (savedGold) document.documentElement.style.setProperty('--gold', savedGold);
    </script>
</body>
</html>