@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        :root { --gold: #D4AF37; --gold-bright: #F9E27D; --glow: rgba(212, 175, 55, 0.4); }
        body { background: url('/images/glitter_bg.png') no-repeat center center fixed; background-size: cover; margin:0; }
        .overlay { position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.85); z-index: -1; }
        .login-card { background: rgba(10, 10, 10, 0.95); border: 2px solid var(--gold); border-radius: 30px; padding: 45px; width: 100%; max-width: 420px; box-shadow: 0 0 40px var(--glow); color: var(--gold); }
        h1 { font-family: 'Cinzel', serif; font-weight: 900; letter-spacing: 8px; text-transform: uppercase; background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .vip-line { width: 60px; height: 3px; background: linear-gradient(to right, transparent, var(--gold), transparent); margin: 0 auto 30px auto; }
        .form-control { background: rgba(255,255,255,0.05) !important; border: 1px solid var(--gold) !important; color: #ffffff !important; font-family: 'JetBrains Mono', monospace; }
        .form-control::placeholder { color: #ffffff !important; opacity: 1 !important; }
        .btn-gold { background: linear-gradient(to bottom, var(--gold-bright), var(--gold)); color: #000; font-weight: 900; border: none; border-radius: 12px; padding: 12px; font-family: 'Cinzel', serif; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        #bypass-area { display: none; animation: fadeIn 0.4s ease-in-out; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="overlay"></div>
    <div class="login-card text-center">
        <div class="mb-2"><i class="bi bi-shield-lock-fill" style="font-size: 2.5rem; filter: drop-shadow(0 0 10px var(--glow));"></i></div>
        <h1>V.I.P Login</h1>
        <div class="vip-line"></div>
        
        <!-- NU GEKOPPELD AAN /Account/Verify -->
        <form action="/Account/Verify" method="post" class="mt-4">
            <input type="text" id="emailInput" name="username" class="form-control mb-3" placeholder="GEBRUIKERSNAAM / E-MAIL" required />
            <input type="password" id="passInput" name="pincode" class="form-control mb-4" placeholder="WACHTWOORD" required />
            <button type="submit" class="btn btn-gold w-100">INLOGGEN</button>
        </form>

        <div class="d-flex justify-content-between mt-3 px-2">
            <!-- LINKS AANGEPAST NAAR /Account/ -->
            <a href="/Account/Register" style="color: var(--gold); text-decoration:none; font-weight:bold; font-size: 0.8rem;">REGISTREREN</a>
            <a href="/Account/ForgotPassword" style="color: var(--gold); text-decoration:none; font-weight:bold; font-size: 0.8rem;">WACHTWOORD VERGETEN</a>
        </div>

        <div id="bypass-area">
            <div style="margin: 35px 0 20px 0; border-top: 1px solid var(--gold); position: relative; opacity: 0.5;">
                <span style="position: absolute; top: -11px; left: 50%; transform: translateX(-50%); background: #0a0a0a; padding: 0 10px; font-size: 0.6rem;">SECURE BYPASS</span>
            </div>
            <!-- BYPASS OOK NAAR /Account/Verify -->
            <form action="/Account/Verify" method="post">
                <input type="password" name="pincode" class="form-control text-center mb-2" placeholder="ADMIN PIN" style="border-style: dashed !important;" required />
                <input type="hidden" name="username" value="ADMIN_BYPASS" />
                <button type="submit" class="btn btn-outline-light w-100 btn-sm" style="color: var(--gold); border-color: var(--gold);">EXECUTE BYPASS</button>
            </form>
        </div>
    </div>

    <script>
        function loadSavedTheme() {
            const savedGold = localStorage.getItem('vip-gold');
            const savedBright = localStorage.getItem('vip-gold-bright');
            const savedGlow = localStorage.getItem('vip-glow');
            if (savedGold) document.documentElement.style.setProperty('--gold', savedGold);
            if (savedBright) document.documentElement.style.setProperty('--gold-bright', savedBright);
            if (savedGlow) document.documentElement.style.setProperty('--glow', savedGlow);
        }

        const emailField = document.getElementById('emailInput');
        const passField = document.getElementById('passInput');
        const bypassArea = document.getElementById('bypass-area');

        function checkBypassTrigger() {
            if (emailField.value === "Admin" && passField.value === "Admin") {
                bypassArea.style.display = "block";
            } else {
                bypassArea.style.display = "none";
            }
        }
        emailField.addEventListener('input', checkBypassTrigger);
        passField.addEventListener('input', checkBypassTrigger);
        loadSavedTheme();
    </script>
</body>
</html>