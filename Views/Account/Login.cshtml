@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>VIP Planning</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Segoe UI', sans-serif; background: #000; }
        .bg-container {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.75)), url('/images/glitter_bg.png') no-repeat center center fixed;
            background-size: cover; z-index: -2;
        }
        .diamonds { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: -1; }
        .diamond { position: absolute; background: rgba(212, 175, 55, 0.6); width: 3px; height: 3px; transform: rotate(45deg); animation: blink 4s infinite ease-in-out; }
        
        /* HIER ZAT DE FOUT: Nu met dubbele @@ */
        @@keyframes blink { 
            0%, 100% { opacity: 0; transform: scale(0.5); } 
            50% { opacity: 1; transform: scale(1.5); box-shadow: 0 0 15px #D4AF37; } 
        }

        .wrapper { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        .login-card { 
            background: rgba(10, 10, 10, 0.85); border: 1px solid rgba(212, 175, 55, 0.4); 
            border-radius: 30px; padding: 40px; width: 100%; max-width: 410px; 
            backdrop-filter: blur(12px); color: white; text-align: center;
        }
        .btn-gold { background: linear-gradient(135deg, #D4AF37, #F5E08F); color: #000; font-weight: 900; border: none; padding: 14px; border-radius: 15px; }
        .form-control { background: rgba(255, 255, 255, 0.05) !important; border: 1px solid rgba(212, 175, 55, 0.2) !important; color: #fff !important; }
    </style>
</head>
<body>
    <div class="bg-container"></div>
    <div class="diamonds" id="diamondContainer"></div>
    <div class="wrapper">
        <div class="login-card">
            <h1 style="color:#D4AF37; font-weight:900; letter-spacing: 6px;">V.I.P</h1>
            <form action="/Account/Verify" method="post" class="mt-4">
                <input type="text" name="username" class="form-control mb-3" placeholder="E-mail" required />
                <input type="password" name="pincode" class="form-control mb-4" placeholder="Wachtwoord" required />
                <button type="submit" class="btn btn-gold w-100">INLOGGEN</button>
            </form>
            <div class="d-flex justify-content-between mt-3 px-2">
                <a href="/Account/Register" style="color:rgba(255,255,255,0.5); text-decoration:none; font-size:0.85rem;">Account maken</a>
            </div>
            <div style="margin: 30px 0; border-top: 1px solid rgba(212, 175, 55, 0.15); position: relative;">
                <span style="position: absolute; top: -11px; left: 50%; transform: translateX(-50%); background: #0a0a0a; padding: 0 10px; color: #D4AF37; font-size: 0.65rem;">SNELTOEGANG</span>
            </div>
            <form action="/Account/Verify" method="post">
                <input type="password" name="pincode" class="form-control text-center mb-2" placeholder="ADMIN PIN" style="border-style: dashed !important;" />
                <input type="hidden" name="username" value="ADMIN_BYPASS" />
                <button type="submit" class="btn btn-outline-warning w-100 btn-sm" style="color:#D4AF37; border-color:#D4AF37;">BYPASS</button>
            </form>
        </div>
    </div>
    <script>
        const container = document.getElementById('diamondContainer');
        for (let i = 0; i < 50; i++) {
            const diamond = document.createElement('div');
            diamond.className = 'diamond';
            diamond.style.left = Math.random() * 100 + '%';
            diamond.style.top = Math.random() * 100 + '%';
            diamond.style.animationDelay = (Math.random() * 5) + 's';
            container.appendChild(diamond);
        }
    </script>
</body>
</html>