@{ Layout = "_LoginLayout"; }
<div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; align-items: center; justify-content: center; background: #000;">
    <div style="background: rgba(15, 15, 15, 0.95); border: 2px solid #D4AF37; border-radius: 40px; padding: 50px; width: 420px; box-shadow: 0 0 70px rgba(212, 175, 55, 0.2); text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 10px;">🔒</div>
        <h2 style="letter-spacing: 3px; font-weight: 900; margin-bottom: 5px; color: #D4AF37;">VIP-PLANNING</h2>
        <p style="color: #888; font-size: 0.7rem; letter-spacing: 2px; margin-bottom: 30px;">BEVEILIGDE OMGEVING</p>
        
        <form action="/Account/Login" method="post">
            <input type="text" name="username" style="background: #111; border: 1px solid #D4AF37; color: #D4AF37; border-radius: 10px; padding: 12px; margin-bottom: 15px; width: 100%; text-align: center;" placeholder="GEBRUIKERSNAAM" />
            <input type="password" name="password" style="background: #111; border: 1px solid #D4AF37; color: #D4AF37; border-radius: 10px; padding: 12px; margin-bottom: 15px; width: 100%; text-align: center;" placeholder="TOEGANGSCODE" />
            <button type="submit" style="background: #D4AF37; color: #000; font-weight: 900; width: 100%; padding: 15px; border-radius: 10px; border: none; cursor: pointer;">INLOGGEN</button>
        </form>
        
        <div style="margin-top: 30px; border-top: 1px solid #333; padding-top: 20px;">
            <p style="color: #D4AF37; font-size: 0.6rem; letter-spacing: 1px; margin-bottom: 10px;">ADMIN SNELKOPPELING</p>
            <input type="password" id="adminPin" style="background: #000; border: 1px dashed #D4AF37; color: #D4AF37; border-radius: 5px; padding: 5px; width: 80px; text-align: center; margin-bottom: 10px;" placeholder="PIN" maxlength="4" />
            <div onclick="checkPin()" id="bypassBtn" style="border: 1px solid #D4AF37; color: #000; background: #D4AF37; padding: 8px; border-radius: 8px; text-align: center; font-size: 0.7rem; font-weight: bold; cursor: pointer; opacity: 0.5;">
                UNLOCKED DASHBOARD
            </div>
        </div>
    </div>
</div>

<script>
    function checkPin() {
        var pin = document.getElementById('adminPin').value;
        if (pin === "3991") {
            window.location.href = "/Account/AdminBypass?pin=3991";
        } else {
            alert("Onjuiste pincode!");
            document.getElementById('adminPin').value = "";
        }
    }

    // Activeer knop visueel als er 4 cijfers staan
    document.getElementById('adminPin').addEventListener('input', function() {
        var btn = document.getElementById('bypassBtn');
        if (this.value.length === 4) {
            btn.style.opacity = "1";
        } else {
            btn.style.opacity = "0.5";
        }
    });
</script>