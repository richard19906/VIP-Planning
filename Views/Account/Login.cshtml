@{ Layout = "_LoginLayout"; }
<div style="background: radial-gradient(circle at center, #1a1a1a 0%, #000 100%); height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Poppins', sans-serif;">
    <div style="background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 30px; padding: 50px; width: 450px; box-shadow: 0 25px 50px rgba(0,0,0,0.5);">
        <h2 style="color: #D4AF37; font-weight: 900; letter-spacing: 5px; margin-bottom: 30px; text-align: center;">VIP LOGIN</h2>
        
        <form action="/Account/Login" method="post">
            <div style="margin-bottom: 20px; text-align: left;">
                <label style="color: #888; font-size: 0.8rem; margin-left: 10px;">E-MAILADRES</label>
                <input type="email" name="email" style="background: rgba(0,0,0,0.5); border: 1px solid #333; border-radius: 12px; color: #fff; padding: 15px; width: 100%; outline: none;" placeholder="naam@voorbeeld.nl">
            </div>
            <div style="margin-bottom: 10px; text-align: left;">
                <label style="color: #888; font-size: 0.8rem; margin-left: 10px;">WACHTWOORD</label>
                <input type="password" name="password" style="background: rgba(0,0,0,0.5); border: 1px solid #333; border-radius: 12px; color: #fff; padding: 15px; width: 100%; outline: none;" placeholder="••••••••">
            </div>
            
            <div style="text-align: right; margin-bottom: 30px;">
                <a href="#" style="color: #D4AF37; font-size: 0.75rem; text-decoration: none; opacity: 0.7;">Wachtwoord vergeten?</a>
            </div>

            <button type="submit" style="background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%); border: none; border-radius: 12px; color: #000; font-weight: 900; padding: 15px; width: 100%; cursor: pointer; text-transform: uppercase;">Inloggen</button>
        </form>

        <div style="margin-top: 25px; color: #666; font-size: 0.85rem; text-align: center;">
            Nog geen account? <a href="#" style="color: #D4AF37; text-decoration: none; font-weight: bold;">Registreer hier</a>
        </div>

        <hr style="border-color: #222; margin: 30px 0;">
        
        <div style="text-align: center;">
            <p style="color: #444; font-size: 0.7rem; letter-spacing: 2px; margin-bottom: 10px;">TIJDELIJKE TOEGANG</p>
            <input type="password" id="adminPin" placeholder="PIN" maxlength="4" style="background: none; border: 1px dashed #444; color: #D4AF37; padding: 10px; width: 80px; text-align: center; border-radius: 8px; margin-right: 10px;">
            <button onclick="bypass()" style="background: none; border: 1px solid #D4AF37; color: #D4AF37; padding: 8px 15px; border-radius: 8px; cursor: pointer; font-size: 0.8rem;">Bypass</button>
        </div>
    </div>
</div>
<script>
    function bypass() {
        const p = document.getElementById('adminPin').value;
        if(p) window.location.href = '/Account/AdminBypass?pin=' + p;
    }
</script>