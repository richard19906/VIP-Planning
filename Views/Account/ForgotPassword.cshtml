@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #D4AF37; --gold-bright: #F9E27D; --glow: rgba(212, 175, 55, 0.4); }
        body { background: url('/images/glitter_bg.png') no-repeat center center fixed; background-size: cover; margin:0; }
        .overlay { position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.85); z-index: -1; }
        .login-card { background: rgba(10, 10, 10, 0.95); border: 2px solid var(--gold); border-radius: 30px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 0 40px var(--glow); color: var(--gold); }
        h1 { font-family: 'Cinzel', serif; font-weight: 900; letter-spacing: 3px; text-transform: uppercase; background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 1.5rem; }
        .form-control { background: rgba(255,255,255,0.05) !important; border: 1px solid var(--gold) !important; color: #ffffff !important; font-family: 'JetBrains Mono', monospace; }
        .form-control::placeholder { color: #ffffff !important; opacity: 0.6 !important; }
        .btn-gold { background: linear-gradient(to bottom, var(--gold-bright), var(--gold)); color: #000; font-weight: 900; border: none; border-radius: 12px; padding: 12px; font-family: 'Cinzel', serif; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="overlay"></div>
    <div class="login-card text-center">
        <h1 class="mb-4">HERSTEL TOEGANG</h1>
        <p class="small mb-4" style="font-family: 'JetBrains Mono'; color: rgba(255,255,255,0.7);">Voer uw e-mailadres in voor een herstelmail.</p>
        
        <form action="/Account/ForgotPassword" method="post">
            <input type="email" name="email" class="form-control mb-4" placeholder="E-MAILADRES" required />
            <button type="submit" class="btn btn-gold w-100 text-uppercase">Code aanvragen</button>
        </form>

        <div class="mt-4">
            <a href="/Account/Login" style="color: var(--gold); text-decoration:none; font-family: 'Cinzel', serif; font-size: 0.8rem;">TERUG NAAR LOGIN</a>
        </div>
    </div>

    <script>
        // Laad thema kleuren uit de interface instellingen
        const savedGold = localStorage.getItem('vip-gold');
        const savedBright = localStorage.getItem('vip-gold-bright');
        const savedGlow = localStorage.getItem('vip-glow');

        if (savedGold) document.documentElement.style.setProperty('--gold', savedGold);
        if (savedBright) document.documentElement.style.setProperty('--gold-bright', savedBright);
        if (savedGlow) document.documentElement.style.setProperty('--glow', savedGlow);
    </script>
</body>
</html>