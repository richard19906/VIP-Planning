@{
    Layout = "_Layout";
}

<div class="container-fluid py-4 px-4">
    <!-- Header Sectie -->
    <div class="mb-5 text-start">
        <!-- V.I.P. PLANNING: Koppeling met --gold-bright en --gold variabelen -->
        <h1 class="vip-main-title">V.I.P. PLANNING</h1>
        
        <!-- De Lijn: Koppeling met --gold variabele -->
        <div class="vip-main-line"></div>
        
        <!-- Ondertitel: Geforceerd op de gekozen goudkleur en exact 0.8rem -->
        <p class="vip-main-subtitle">Beheer het systeem, de planning en de personeelsuren.</p>
    </div>

    <!-- Dashboard Kaarten -->
    <div class="row g-4">
        <div class="col-md-4">
            <a href="/Home/Planning" class="vip-card-link">
                <div class="vip-dashboard-card">
                    <div class="card-body p-4 text-center">
                        <div class="vip-card-icon">📅</div>
                        <h3 class="vip-card-title">Planning</h3>
                        <p class="vip-card-text">Beheer roosters en diensten.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/Home/Werknemers" class="vip-card-link">
                <div class="vip-dashboard-card">
                    <div class="card-body p-4 text-center">
                        <div class="vip-card-icon">👥</div>
                        <h3 class="vip-card-title">Werknemers</h3>
                        <p class="vip-card-text">Bekijk uren en profielen.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/Home/Instellingen" class="vip-card-link">
                <div class="vip-dashboard-card">
                    <div class="card-body p-4 text-center">
                        <div class="vip-card-icon">⚙️</div>
                        <h3 class="vip-card-title">Instellingen</h3>
                        <p class="vip-card-text">Systeemstatus en portal beheer.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    /* TITEL STYLING: Gebruikt de variabelen uit de Layout */
    .vip-main-title {
        font-family: 'Cinzel', serif !important;
        font-weight: 900 !important;
        font-size: 2.5rem !important;
        letter-spacing: 5px !important;
        background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        margin: 0 !important;
        text-transform: uppercase !important;
        display: inline-block !important;
        text-shadow: 0 0 15px var(--glow) !important;
        transition: 0.5s ease;
    }

    /* GOUDEN LIJN: Gebruikt de Layout variabele */
    .vip-main-line {
        width: 150px;
        height: 3px;
        background: linear-gradient(to right, var(--gold), transparent);
        margin: 15px 0 15px 0;
        box-shadow: 0 0 10px var(--glow);
        transition: 0.5s ease;
    }

    /* ONDERTITEL: Exact 0.8rem en Goud */
    .vip-main-subtitle {
        color: var(--gold) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 0.8rem !important;
        font-weight: 700 !important;
        letter-spacing: 1px !important;
        text-transform: uppercase !important;
        margin: 0 !important;
        opacity: 1 !important;
        text-shadow: 0 0 5px var(--glow) !important;
        transition: 0.5s ease;
    }

    /* KAART STYLING */
    .vip-card-link {
        text-decoration: none !important;
    }

    .vip-dashboard-card {
        background: linear-gradient(145deg, #111, #050505);
        border: 1px solid var(--gold);
        border-radius: 15px;
        transition: all 0.4s ease;
        height: 100%;
    }

        .vip-dashboard-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px var(--glow);
            border-color: var(--gold-bright);
        }

    .vip-card-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .vip-card-title {
        font-family: 'Cinzel', serif;
        color: var(--gold);
        font-weight: 700;
        font-size: 1.2rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: 0.5s ease;
    }

    .vip-card-text {
        color: var(--gold);
        font-size: 0.75rem;
        opacity: 0.8;
        transition: 0.5s ease;
    }
</style>