@model List<VIP_Planning.Models.UrenModel>
@{ Layout = "_Layout"; }

<div class="d-flex justify-content-between align-items-center">
    <h1 style="font-weight:900;">GEWERKTE <span style="color:#D4AF37;">UREN</span></h1>
    <span class="badge" style="border: 1px solid #D4AF37; color: #D4AF37;">@Model.Count REGISTRATIES</span>
</div>

<div class="table-responsive mt-4">
    <table class="table table-dark table-hover" style="border: 1px solid #333; background: #0a0a0a;">
        <thead>
            <tr style="color: #D4AF37; border-bottom: 2px solid #D4AF37;">
                <th>DATUM</th>
                <th>LOCATIE</th>
                <th>PERIODE</th>
                <th>UREN</th>
                <th>STATUS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderByDescending(x => x.Datum)) {
                <tr>
                    <td>@item.Datum.ToShortDateString()</td>
                    <td>@item.Locatie</td>
                    <td style="color: #888;">@item.PeriodeNaam</td>
                    <td style="font-weight: bold;">@item.AantalUren</td>
                    <td>
                        @if(item.IsUitbetaald) {
                            <span class="badge bg-success" style="font-size: 0.6rem;">UITBETAALD</span>
                        } else {
                            <span class="badge bg-warning text-dark" style="font-size: 0.6rem;">OPENSTAAND</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>