@{ Layout = "_Layout"; }
<div class="animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h4 style="color: #D4AF37; letter-spacing: 5px; font-weight: 200; margin: 0;">CONTROLE PANEEL</h4>
            <h1 style="font-size: 2.5rem; font-weight: 900; letter-spacing: 2px;">OVERZICHT <span style="color: #D4AF37;">VANDAAG</span></h1>
        </div>
        <div id="klok" style="font-size: 2rem; color: #D4AF37; border: 1px solid #D4AF37; padding: 10px 30px; border-radius: 50px; background: rgba(0,0,0,0.5); font-family: monospace;">00:00:00</div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div style="background: rgba(10,10,10,0.8); border: 1px solid #D4AF37; border-radius: 20px; padding: 30px; text-align: center;">
                <p style="color: #888; font-size: 0.8rem; letter-spacing: 2px;">ACTIEF PERSONEEL</p>
                <h2 style="color: #D4AF37; font-size: 3rem; font-weight: 900;">12</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div style="background: rgba(10,10,10,0.8); border: 1px solid #D4AF37; border-radius: 20px; padding: 30px; text-align: center;">
                <p style="color: #888; font-size: 0.8rem; letter-spacing: 2px;">OPENSTAANDE DIENSTEN</p>
                <h2 style="color: #D4AF37; font-size: 3rem; font-weight: 900;">04</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div style="background: rgba(10,10,10,0.8); border: 1px solid #D4AF37; border-radius: 20px; padding: 30px; text-align: center;">
                <p style="color: #888; font-size: 0.8rem; letter-spacing: 2px;">SYSTEEM STATUS</p>
                <h2 style="color: #00ff00; font-size: 3rem; font-weight: 900;">LIVE</h2>
            </div>
        </div>
    </div>
</div>

<script>
    function updateTijd() {
        document.getElementById('klok').innerText = new Date().toLocaleTimeString('nl-NL');
    }
    setInterval(updateTijd, 1000);
    updateTijd();
</script>