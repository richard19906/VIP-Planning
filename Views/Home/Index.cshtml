@{ Layout = "_Layout"; }
<div class="container-fluid">
    <div class="mb-5">
        <h1 style="color:#D4AF37; font-size: 3.5rem; font-weight:900;">WELCOME V.I.P ELITE</h1>
        <p class="text-white-50">Kies een module om het systeem te beheren.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-4 text-center" style="background: rgba(20,20,20,0.8); border: 1px solid #D4AF37; border-radius: 15px;">
                <div style="font-size: 3rem; margin-bottom: 15px;">📅</div>
                <h3 style="color:#D4AF37;">Planning</h3>
                <p class="text-white-50">Beheer het rooster en voeg nieuwe diensten toe.</p>
                <a href="/Home/Planning" class="btn btn-gold w-100 py-3" style="background:#D4AF37; color:#000; font-weight:900;">OPEN PLANNING</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 text-center" style="background: rgba(20,20,20,0.8); border: 1px solid #D4AF37; border-radius: 15px;">
                <div style="font-size: 3rem; margin-bottom: 15px;">👥</div>
                <h3 style="color:#D4AF37;">Werknemers</h3>
                <p class="text-white-50">Bekijk urenoverzichten en profielen van personeel.</p>
                <a href="/Home/Werknemers" class="btn btn-gold w-100 py-3" style="background:#D4AF37; color:#000; font-weight:900;">BEHEER TEAM</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 text-center" style="background: rgba(20,20,20,0.8); border: 1px solid #D4AF37; border-radius: 15px;">
                <div style="font-size: 3rem; margin-bottom: 15px;">⚙️</div>
                <h3 style="color:#D4AF37;">Instellingen</h3>
                <p class="text-white-50">Bekijk systeemstatus en configuratie.</p>
                <a href="/Home/Instellingen" class="btn btn-gold w-100 py-3" style="background:#D4AF37; color:#000; font-weight:900;">CONFIGURATIE</a>
            </div>
        </div>
    </div>
</div>