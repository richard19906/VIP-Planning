@{ Layout = "_Layout"; }
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📊 UREN: @ViewBag.Naam</h2>
        <a href="/Home/ExportUrenPdf?naam=@ViewBag.Naam" class="btn btn-gold">📄 EXPORT PDF</a>
    </div>
    <div class="card p-4" style="background:rgba(10,10,10,0.9); border:2px solid #D4AF37; border-radius:20px;">
        <table class="table" style="color:#D4AF37;">
            <thead>
                <tr><th>DATUM</th><th>LOCATIE</th><th>UREN</th></tr>
            </thead>
            <tbody>
                </tbody>
        </table>
        <button class="btn btn-outline-warning mt-3" onclick="history.back()">TERUG NAAR WERKNEMERS</button>
    </div>
</div>