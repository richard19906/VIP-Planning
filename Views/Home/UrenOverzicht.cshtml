@model List<VIP_Planning.Models.PlanningModel>
@{ Layout = "_Layout"; }
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:900;">📊 URENVERANTWOORDING: @ViewBag.Naam</h2>
        <a href="/Home/ExportUrenPdf?naam=@ViewBag.Naam" class="btn btn-gold">📄 EXPORT PDF</a>
    </div>
    <div class="card p-0" style="background:rgba(10,10,10,0.9); border:2px solid #D4AF37; border-radius:20px; overflow:hidden;">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th class="p-3">DATUM</th>
                    <th class="p-3">LOCATIE</th>
                    <th class="p-3">UREN (Systeem)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var item in Model) {
                        <tr>
                            <td class="p-3">@item.Datum</td>
                            <td class="p-3">@item.Locatie</td>
                            <td class="p-3">@item.Uren</td>
                        </tr>
                    }
                } else {
                    <tr><td colspan="3" class="p-4 text-center text-white">Geen uren gevonden in Supabase voor deze VIP.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <button class="btn btn-outline-warning mt-4" onclick="history.back()">TERUG NAAR WERKNEMERS</button>
</div>