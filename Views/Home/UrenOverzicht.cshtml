@model List<VIP_Planning.Models.PlanningModel>
@{ Layout = "_Layout"; }
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:900;">📊 URENVERANTWOORDING: @ViewBag.Naam</h2>
        <a href="/Home/ExportUrenPdf?naam=@ViewBag.Naam" class="btn btn-gold">📄 EXPORT PDF</a>
    </div>
    <div class="card p-0" style="background:rgba(10,10,10,0.9); border:2px solid #D4AF37; border-radius:20px; overflow:hidden;">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th class="p-3">DATUM</th>
                    <th class="p-3">LOCATIE</th>
                    <th class="p-3">UREN</th>
                    <th class="p-3">TOESLAG</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var item in Model) {
                        <tr>
                            <td class="p-3">@item.Datum</td>
                            <td class="p-3">@item.Locatie</td>
                            <td class="p-3">@item.Uren</td>
                            <td class="p-3">
                                @if(item.Uren.Contains("*")) { <span class="text-warning">125% (*)</span> }
                                else if(item.Uren.Contains("**")) { <span class="text-danger">150% (**)</span> }
                                else { <span>100%</span> }
                            </td>
                        </tr>
                    }
                } else {
                    <tr><td colspan="4" class="p-4 text-center">Geen data gevonden in Supabase.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>