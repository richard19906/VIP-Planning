@model List<VIP_Planning.Models.UrenModel>
@{
    Layout = "_Layout";

    // Bereken totalen met uitsluiting van 'vrij' en 'ziek'
    double totaalUrenMaand = Model?.Where(u =>
        !(u.Locatie?.ToLower().Contains("vrij") ?? false) &&
        !(u.Locatie?.ToLower().Contains("ziek") ?? false)
    ).Sum(u => u.Uren) ?? 0;

    double totaalOpenstaand = Model?.Where(u =>
        !u.IsUitbetaald &&
        !(u.Locatie?.ToLower().Contains("vrij") ?? false) &&
        !(u.Locatie?.ToLower().Contains("ziek") ?? false)
    ).Sum(u => u.Uren) ?? 0;
}

<style>
    :root {
        --gold: #D4AF37;
        --gold-bright: #F9E27D;
        --glow: rgba(212, 175, 55, 0.4);
    }

    .vip-card-overzicht {
        background: rgba(10, 10, 10, 0.95);
        border: 2px solid var(--gold);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.8), 0 0 25px var(--glow);
    }

    .vip-total-card {
        background: linear-gradient(145deg, rgba(20,20,20,0.9), rgba(10,10,10,0.95));
        border: 1px solid var(--gold);
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        text-align: center;
    }

    .total-item h4 {
        color: var(--gold);
        font-family: 'Cinzel', serif;
        font-size: 0.8rem;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .total-item p {
        color: white;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.8rem;
        font-weight: 900;
        margin: 0;
        text-shadow: 0 0 10px var(--glow);
    }

    .vip-table-overzicht thead th {
        color: var(--gold);
        font-family: 'Cinzel', serif;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid var(--gold);
        font-size: 0.9rem;
        padding: 15px;
    }

    .vip-table-overzicht tbody tr {
        border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    }

    .vip-table-overzicht tbody td {
        padding: 15px;
        color: white;
    }

    .maand-pills .btn {
        border: 1px solid rgba(212, 175, 55, 0.3);
        color: rgba(255, 255, 255, 0.7);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        margin: 3px;
        padding: 6px 14px;
    }

        .maand-pills .btn.active-gold {
            background: var(--gold);
            color: black !important;
            font-weight: 800;
        }

    .vip-header-title-main {
        font-family: 'Cinzel', serif;
        font-weight: 900;
        font-size: 2.2rem;
        background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-vip-gold-md {
        background: linear-gradient(to bottom, var(--gold-bright), var(--gold));
        color: black;
        font-weight: 900;
        border: none;
        border-radius: 10px;
        padding: 8px 20px;
    }

    .btn-vip-delete {
        background: transparent;
        color: #ff4444;
        border: 1px solid #ff4444;
        border-radius: 10px;
        padding: 8px 12px;
    }

    .badge-verwerkt {
        border: 1px solid #28a745;
        color: #28a745;
        padding: 5px 15px;
        border-radius: 6px;
        font-weight: 700;
    }
</style>

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="vip-header-title-main">📊 UREN: @ViewBag.Naam.ToUpper()</h1>
            <p style="color: var(--gold); font-family: 'Cinzel';">PERIODE: @ViewBag.GeselecteerdeMaand</p>
        </div>
        <a href="/Uren/ExportPdf?email=@ViewBag.Email&naam=@ViewBag.Naam&maand=@ViewBag.GeselecteerdeMaand" class="btn btn-vip-gold-md">
            <i class="bi bi-file-earmark-pdf-fill me-2"></i> PDF EXPORT
        </a>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="maand-pills p-2 rounded-pill" style="background: rgba(0,0,0,0.5); border: 1px solid rgba(212,175,55,0.3);">
            @foreach (var m in (List<string>)ViewBag.Maanden)
            {
                <a href="/Home/UrenOverzicht?email=@ViewBag.Email&naam=@ViewBag.Naam&maand=@m"
                       class="btn rounded-pill @(ViewBag.GeselecteerdeMaand == m ? "active-gold" : "")">
                    @m.ToUpper()
                </a>
            }
        </div>
    </div>

    <!-- Totaal Overzicht Kaart -->
    <div class="vip-total-card shadow">
        <div class="total-item">
            <h4>Totaal Gewerkt</h4>
            <p>@totaalUrenMaand.ToString("N1")</p>
        </div>
        <div style="width: 1px; height: 40px; background: rgba(212,175,55,0.3);"></div>
        <div class="total-item">
            <h4>Nog Openstaand</h4>
            <p style="color: var(--gold-bright);">@totaalOpenstaand.ToString("N1")</p>
        </div>
    </div>

    <div class="vip-card-overzicht">
        <div class="table-responsive">
            <table class="table table-dark align-middle vip-table-overzicht mb-0">
                <thead>
                    <tr>
                        <th>DATUM</th>
                        <th>LOCATIE</th>
                        <th class="text-center">UREN</th>
                        <th class="text-end">ACTIE</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.DatumString</td>
                                <td>@item.Locatie.ToUpper()</td>
                                <td class="text-center" style="font-family: 'JetBrains Mono'; color: var(--gold); font-weight: 900; font-size: 1.3rem;">
                                    @item.DisplayUren
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        @if (!item.IsUitbetaald)
                                        {
                                            <form action="/Uren/MarkeerAlsBetaald" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="email" value="@ViewBag.Email" />
                                                <input type="hidden" name="naam" value="@ViewBag.Naam" />
                                                <input type="hidden" name="maand" value="@ViewBag.GeselecteerdeMaand" />
                                                <button type="submit" class="btn btn-vip-gold-md">UITBETALEN</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge-verwerkt">VERWERKT</span>
                                        }

                                        <form action="/Uren/VerwijderUren" method="post" class="d-inline" onsubmit="return confirm('Verwijderen?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="email" value="@ViewBag.Email" />
                                            <input type="hidden" name="naam" value="@ViewBag.Naam" />
                                            <input type="hidden" name="maand" value="@ViewBag.GeselecteerdeMaand" />
                                            <button type="submit" class="btn btn-vip-delete">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>