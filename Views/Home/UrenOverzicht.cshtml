@model List<VIP_Planning.Models.UrenModel>
@{
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white mb-0">📊 UREN: @ViewBag.Naam</h2>
            <small class="text-gold">Periode: @ViewBag.GeselecteerdeMaand</small>
        </div>
        <a href="/Uren/ExportPdf?email=@ViewBag.Email&naam=@ViewBag.Naam&maand=@ViewBag.GeselecteerdeMaand" class="btn btn-gold shadow">
            📄 PDF EXPORT
        </a>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group bg-black p-1 rounded border border-warning">
            @foreach (var m in (List<string>)ViewBag.Maanden)
            {
                <a href="/Home/UrenOverzicht?email=@ViewBag.Email&naam=@ViewBag.Naam&maand=@m"
                       class="btn @(ViewBag.GeselecteerdeMaand == m ? "btn-gold" : "text-warning")">
                    @m.ToUpper()
                </a>
            }
        </div>
    </div>

    <div class="card bg-black border-warning overflow-hidden shadow-lg">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr class="text-gold border-bottom border-warning">
                    <th>DATUM</th>
                    <th>LOCATIE</th>
                    <th class="text-center">UREN</th>
                    <th class="text-end">ACTIE</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.DatumString</td>
                            <td class="align-middle">@item.Locatie</td>
                            <td class="align-middle text-center fw-bold text-gold" style="font-size: 1.1rem;">
                                @item.DisplayUren
                            </td>
                            <td class="align-middle text-end">
                                @if (!item.IsUitbetaald)
                                {
                                    <form action="/Uren/MarkeerAlsBetaald" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="email" value="@ViewBag.Email" />
                                        <input type="hidden" name="naam" value="@ViewBag.Naam" />
                                        <input type="hidden" name="maand" value="@ViewBag.GeselecteerdeMaand" />
                                        <button type="submit" class="btn btn-sm btn-gold px-3">UITBETALEN</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge border border-success text-success px-3 py-2">VERWERKT</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted italic">
                            Geen gegevens gevonden voor deze periode.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .btn-gold {
        background-color: #d4af37;
        color: black;
        font-weight: bold;
        border: 1px solid #d4af37;
    }

        .btn-gold:hover {
            background-color: black;
            color: #d4af37;
        }

    .text-gold {
        color: #d4af37 !important;
    }

    .border-warning {
        border-color: #d4af37 !important;
    }

    .bg-black {
        background-color: #000 !important;
    }
</style>