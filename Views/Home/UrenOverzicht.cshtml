@model List<VIP_Planning.Models.UrenModel>
@{ Layout = "_Layout"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 UREN: @ViewBag.Naam</h2>
    <a href="/Home/ExportUrenPdf?email=@ViewBag.Email&naam=@ViewBag.Naam&maand=@ViewBag.GeselecteerdeMaand" class="btn btn-gold">📄 PDF EXPORT</a>
</div>

<div class="d-flex justify-content-center mb-4">
    <div class="btn-group">
        @foreach(var m in (List<string>)ViewBag.Maanden) {
            <a href="/Home/UrenOverzicht?email=@ViewBag.Email&naam=@ViewBag.Naam&maand=@m" 
               class="btn @(ViewBag.GeselecteerdeMaand == m ? "btn-gold" : "btn-outline-warning")">@m.ToUpper()</a>
        }
    </div>
</div>

<div class="card bg-black border-warning overflow-hidden">
    <table class="table table-dark mb-0">
        <thead>
            <tr class="text-gold"><th>DATUM</th><th>LOCATIE</th><th>UREN</th><th>ACTIE</th></tr>
        </thead>
        <tbody>
            @foreach(var item in Model) {
                <tr>
                    <td>@item.DatumString</td>
                    <td>@item.Locatie</td>
                    <td style="font-weight:bold;">@item.DisplayUren</td>
                    <td>
                        @if(!item.IsUitbetaald) {
                            <form action="/Home/MarkeerAlsBetaald" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="email" value="@ViewBag.Email" />
                                <input type="hidden" name="naam" value="@ViewBag.Naam" />
                                <input type="hidden" name="maand" value="@ViewBag.GeselecteerdeMaand" />
                                <button type="submit" class="btn btn-sm btn-gold">UITBETALEN</button>
                            </form>
                        } else {
                            <span class="badge border border-success text-success">VERWERKT</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>