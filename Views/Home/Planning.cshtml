@model List<VIP_Planning.Models.PlanningModel>
@{
    Layout = "_Layout";
    var werknemers = (List<VIP_Planning.Models.ProfielModel>)ViewBag.Werknemers;
    var culture = new System.Globalization.CultureInfo("nl-NL");
    var huidigeMaandShort = DateTime.Now.ToString("MMM", culture);
    huidigeMaandShort = char.ToUpper(huidigeMaandShort[0]) + huidigeMaandShort.Substring(1).Replace(".", "");
    var geselecteerdeMaand = ViewBag.GeselecteerdeMaand ?? huidigeMaandShort;
}

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Inter:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --gold: #D4AF37;
        --gold-bright: #F9E27D;
        --glow: rgba(212, 175, 55, 0.4);
    }

    .mono { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; }
    
    .vip-header-title-main {
        font-family: 'Cinzel', serif;
        font-weight: 900; font-size: 2.2rem; letter-spacing: 3px;
        background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        text-shadow: 0 0 15px var(--glow); text-transform: uppercase;
    }

    /* MAAND SELECTOR */
    .maand-selector { display: flex; gap: 5px; flex-wrap: wrap; }
    .btn-maand {
        color: white !important;
        text-decoration: none;
        padding: 5px 12px;
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 4px;
        font-size: 0.8rem;
        transition: 0.3s;
        text-transform: uppercase;
    }
    .btn-maand.active {
        background: var(--gold) !important;
        color: black !important;
        font-weight: bold;
        box-shadow: 0 0 10px var(--glow);
    }

    /* INVOER BALK */
    .vip-card-glow {
        background: #0a0a0a;
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 15px;
    }

    .vip-label { color: var(--gold); font-size: 0.75rem; font-weight: bold; margin-bottom: 8px; display: block; }
    
    .vip-input {
        background: #000 !important;
        color: #ffffff !important;
        -webkit-text-fill-color: #ffffff !important;
        border: 1px solid #333 !important;
        border-radius: 8px;
    }

    .vip-input:focus {
        border-color: var(--gold) !important;
        box-shadow: 0 0 8px var(--glow);
    }

    .btn-voegtoe {
        background: var(--gold);
        color: #000;
        font-weight: bold;
        border: none;
        border-radius: 8px;
        padding: 10px;
        transition: 0.3s;
    }
    .btn-voegtoe:hover { background: var(--gold-bright); transform: translateY(-2px); }

    /* BEHEER KNOPPEN */
    .btn-action-edit, .btn-action-delete {
        background: none;
        border: 1px solid rgba(212, 175, 55, 0.3);
        color: var(--gold);
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }
    .btn-action-edit:hover { background: var(--gold); color: black; }
    .btn-action-delete:hover { background: #ff4444; color: white; border-color: #ff4444; }

    /* TABEL STYLING */
    .vip-card-black-glow { background: #000; border: 1px solid rgba(212, 175, 55, 0.1); border-radius: 15px; }
    .vip-table tbody td { border-bottom: 1px solid rgba(212, 175, 55, 0.05); padding: 12px 10px; color: white; }
    
    .badge-status.gepland {
        background: rgba(212, 175, 55, 0.1);
        color: var(--gold);
        border: 1px solid var(--gold);
        padding: 2.5px 8px;
        border-radius: 4px;
        font-size: 0.65rem;
    }
</style>

<div class="container-fluid py-4 px-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="vip-header-title-main">ROOSTER BEHEER</h1>
            <div style="width: 100px; height: 3px; background: linear-gradient(to right, var(--gold), transparent); margin-top: 10px;"></div>
        </div>
        <div class="maand-selector">
            @foreach (var m in new[] { "Jan", "Feb", "Mrt", "Apr", "Mei", "Jun", "Jul", "Aug", "Sep", "Okt", "Nov", "Dec" })
            {
                <a href="?maand=@m" class="btn-maand @(geselecteerdeMaand == m ? "active" : "")">@m</a>
            }
        </div>
    </div>

    <!-- Invoer Balk -->
    <div class="vip-card-glow mb-4">
        <div class="p-4">
            <form action="/Home/OpslaanLokaal" method="post" id="planningForm" class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="vip-label">WERKNEMER</label>
                    <select name="UserEmail" id="inputEmail" class="form-select vip-input" required>
                        <option value="">-- SELECTEER --</option>
                        @foreach (var w in werknemers) { 
                            <option value="@w.Email">@w.Naam.ToUpper()</option> 
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="vip-label">DATUM</label>
                    <input name="DatumString" id="inputDatum" class="form-control vip-input" type="date" required />
                </div>
                <div class="col-md-3">
                    <label class="vip-label">LOCATIE</label>
                    <input name="Locatie" id="inputLocatie" class="form-control vip-input" placeholder="Voer locatie in..." required />
                </div>
                <div class="col-md-1">
                    <label class="vip-label">START</label>
                    <input name="StartTijd" id="invoerStart" type="text" class="form-control vip-input px-2 text-center" placeholder="08:00" maxlength="5" required />
                </div>
                <div class="col-md-1">
                    <label class="vip-label">EINDE</label>
                    <input name="EindTijd" id="invoerEind" type="text" class="form-control vip-input px-2 text-center" placeholder="17:00" maxlength="5" required />
                </div>
                <div class="col-md-1">
                    <label class="vip-label">UREN</label>
                    <input name="Uren" id="invoerUren" type="number" step="0.1" class="form-control vip-input px-2 text-center" value="8.0" required />
                </div>
                <div class="col-md-2">
                    <button type="submit" id="submitBtn" class="btn-voegtoe w-100">VOEG TOE</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Rooster Tabel -->
    <div class="vip-card-black-glow mb-4">
        <div class="p-4">
            <div class="table-responsive">
                <table class="table table-dark vip-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;"></th>
                            <th class="text-gold">DATUM</th>
                            <th class="text-gold">WERKNEMER</th>
                            <th class="text-gold">LOCATIE</th>
                            <th class="text-center text-gold">START</th>
                            <th class="text-center text-gold">EINDE</th>
                            <th class="text-center text-gold">UREN</th>
                            <th class="text-center text-gold">STATUS</th>
                            <th class="text-end text-gold">BEHEER</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center"><i class="bi bi-circle text-muted" style="opacity: 0.2;"></i></td>
                                <td>@DateTime.Parse(item.Datum).ToString("dd-MM-yyyy")</td>
                                <td class="fw-bold">@item.UserNaam</td>
                                <td>@item.Locatie</td>
                                <td class="text-center mono" style="color:var(--gold);">@(item.StartTijd ?? "00:00")</td>
                                <td class="text-center mono" style="color:var(--gold);">@(item.EindTijd ?? "00:00")</td>
                                <td class="text-center text-white fw-bold mono">@item.Uren.ToString("N1")</td>
                                <td class="text-center">
                                    <span class="badge-status gepland">@(item.Status ?? "Gepland")</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        <button class="btn-action-edit" onclick="editPlanning('@item.Id', '@item.UserEmail', '@item.Datum', '@item.Locatie', '@item.StartTijd', '@item.EindTijd', '@item.Uren')">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn-action-delete" onclick="confirmDelete('@item.Id')">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Automatische dubbele punt en urenberekening
    const timeFields = [document.getElementById('invoerStart'), document.getElementById('invoerEind')];
    timeFields.forEach(field => {
        field.addEventListener('input', (e) => {
            let val = e.target.value.replace(/\D/g, '');
            if (val.length >= 3) {
                e.target.value = val.slice(0, 2) + ':' + val.slice(2, 4);
            }
            berekenUren();
        });
    });

    function berekenUren() {
        const start = document.getElementById('invoerStart').value;
        const eind = document.getElementById('invoerEind').value;
        const urenVeld = document.getElementById('invoerUren');
        if (start.length === 5 && eind.length === 5) {
            const [startH, startM] = start.split(':').map(Number);
            const [eindH, eindM] = eind.split(':').map(Number);
            let diff = (eindH * 60 + eindM) - (startH * 60 + startM);
            if (diff < 0) diff += 1440;
            urenVeld.value = (diff / 60).toFixed(1);
        }
    }

    // 2. Edit Functie
    function editPlanning(id, email, datum, locatie, start, eind, uren) {
        document.getElementById('inputEmail').value = email;
        document.getElementById('inputLocatie').value = locatie;
        document.getElementById('invoerStart').value = start;
        document.getElementById('invoerEind').value = eind;
        document.getElementById('invoerUren').value = uren;

        // Datum fix (ISO string naar yyyy-mm-dd)
        if(datum) {
            const d = new Date(datum);
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            document.getElementById('inputDatum').value = `${year}-${month}-${day}`;
        }

        // Formulier omzetten naar bewerk-modus
        document.getElementById('submitBtn').innerText = "BIJWERKEN";
        document.getElementById('submitBtn').style.background = "#ffffff";
        
        // Hidden ID input toevoegen of bijwerken
        let idInput = document.getElementById('editId');
        if(!idInput) {
            idInput = document.createElement('input');
            idInput.type = 'hidden'; idInput.name = 'Id'; idInput.id = 'editId';
            document.getElementById('planningForm').appendChild(idInput);
        }
        idInput.value = id;
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // 3. Delete Functie met SweetAlert
    function confirmDelete(id) {
        Swal.fire({
            title: 'WIERWIJDEREN?',
            text: "Dienst wordt permanent verwijderd uit het rooster.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#D4AF37',
            cancelButtonColor: '#d33',
            confirmButtonText: 'JA, VERWIJDEREN',
            cancelButtonText: 'ANNULEREN',
            background: '#0a0a0a',
            color: '#ffffff'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Home/Verwijderen/' + id;
            }
        });
    }
</script>