@model List<VIP_Planning.Models.PlanningModel>
@{
    Layout = "_Layout";
    var werknemers = (List<VIP_Planning.Models.ProfielModel>)ViewBag.Werknemers;

    // Logica om de huidige maand als standaard te zetten als er geen selectie is
    var huidigeMaandShort = DateTime.Now.ToString("MMM", new System.Globalization.CultureInfo("nl-NL"));
    huidigeMaandShort = char.ToUpper(huidigeMaandShort[0]) + huidigeMaandShort.Substring(1).Replace(".", "");
    
    var geselecteerdeMaand = ViewBag.GeselecteerdeMaand ?? huidigeMaandShort;
}

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Inter:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid py-4 px-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="vip-header-title-main">ROOSTER BEHEER</h1>
            <div class="vip-gold-line-main"></div>
        </div>
        <div class="maand-selector">
            @foreach (var m in new[] { "Jan", "Feb", "Mrt", "Apr", "Mei", "Jun", "Jul", "Aug", "Sep", "Okt", "Nov", "Dec" })
            {
                <a href="?maand=@m" class="btn-maand @(geselecteerdeMaand == m ? "active" : "")">@m</a>
            }
        </div>
    </div>

    <!-- Invoer Balk -->
    <div class="vip-card-glow mb-4">
        <div class="p-4">
            <form action="/Home/OpslaanLokaal" method="post" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="vip-label">WERKNEMER</label>
                    <select name="UserEmail" class="form-select vip-input" required>
                        <option value="">-- SELECTEER --</option>
                        @foreach (var w in werknemers) { <option value="@w.Email">@w.Naam.ToUpper()</option> }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="vip-label">DATUM</label>
                    <input name="DatumString" class="form-control vip-input custom-date" type="date" required />
                </div>
                <div class="col-md-3">
                    <label class="vip-label">LOCATIE</label>
                    <input name="Locatie" class="form-control vip-input" placeholder="Voer locatie in..." required />
                </div>
                <div class="col-md-1">
                    <label class="vip-label">UREN</label>
                    <input name="Uren" type="number" step="0.5" class="form-control vip-input" value="0" required />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn-voegtoe w-100">TOEVOEGEN</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Rooster Tabel -->
    <div class="vip-card-black-glow mb-4">
        <div class="p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-gold-gradient fw-bold mb-0">LIVE PLANNING STATUS - @geselecteerdeMaand.ToUpper()</h5>
                <form action="/Home/PushNaarDatabase" method="post" onsubmit="showPublishFeedback(event, this)">
                    <button type="submit" id="publishBtn" class="btn-push-small">
                        <i class="bi bi-send-fill me-1"></i> PUBLICEER ROOSTER
                    </button>
                </form>
            </div>
            
            <div class="table-responsive">
                <table class="table table-dark vip-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;"></th> <!-- Vinkje Kolom -->
                            <th class="text-gold">DATUM</th>
                            <th class="text-gold">WERKNEMER</th>
                            <th class="text-gold">LOCATIE</th>
                            <th class="text-center text-gold">START</th>
                            <th class="text-center text-gold">EINDE</th>
                            <th class="text-center text-gold">STATUS</th>
                            <th class="text-end text-gold">BEHEER</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            bool isVoltooid = item.Status == "Voltooid";
                            <tr>
                                <td class="text-center">
                                    @if (isVoltooid) {
                                        <i class="bi bi-check-circle-fill text-success" style="font-size: 1.1rem;"></i>
                                    } else {
                                        <i class="bi bi-circle text-muted" style="opacity: 0.2;"></i>
                                    }
                                </td>
                                <td class="text-white">@DateTime.Parse(item.Datum).ToString("dd-MM-yyyy")</td>
                                <td class="text-white fw-bold">@item.UserNaam</td>
                                <td class="text-white">@item.Locatie</td>
                                <td class="text-center text-gold-var mono">@(string.IsNullOrEmpty(item.StartTijd) ? "--:--" : item.StartTijd)</td>
                                <td class="text-center text-gold-var mono">@(string.IsNullOrEmpty(item.EindTijd) ? "--:--" : item.EindTijd)</td>
                                <td class="text-center">
                                    <span class="badge-status @(item.Status?.ToLower() ?? "gepland")">
                                        @(item.Status ?? "Gepland")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button onclick="editRow('@item.Id', '@item.Locatie', '@item.Uren')" class="btn-action-edit me-3">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button onclick="confirmDelete('@item.Id')" class="btn-action-delete">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                    <form id="delete-form-@item.Id" action="/Home/VerwijderPlanning" method="post" style="display:none;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    :root { 
        --gold: #D4AF37; 
        --gold-bright: #F9E27D;
        --glow: rgba(212, 175, 55, 0.4); 
    }
    
    .mono { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; }

    /* Maand Kiezer Styling */
    .maand-selector { display: flex; gap: 5px; flex-wrap: wrap; }
    .btn-maand {
        color: white !important;
        text-decoration: none;
        padding: 5px 12px;
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 4px;
        font-size: 0.8rem;
        transition: 0.3s;
        text-transform: uppercase;
    }
    .btn-maand:hover { border-color: var(--gold); background: rgba(212, 175, 55, 0.1); color: var(--gold) !important; }
    .btn-maand.active { 
        background: var(--gold) !important; 
        color: black !important; 
        font-weight: bold; 
        box-shadow: 0 0 10px var(--glow); 
        border-color: var(--gold);
    }

    /* Status Badges */
    .badge-status {
        padding: 3px 10px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        border: 1px solid transparent;
    }
    .badge-status.gepland { border-color: #444; color: #888; }
    .badge-status.bezig { border-color: var(--gold); color: var(--gold); background: rgba(212,175,55,0.1); box-shadow: 0 0 5px var(--glow); }
    .badge-status.voltooid { border-color: #28a745; color: #28a745; background: rgba(40,167,69,0.1); }

    .vip-header-title-main {
        font-family: 'Cinzel', serif;
        font-weight: 900; font-size: 2.2rem; letter-spacing: 3px;
        background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        text-shadow: 0 0 15px var(--glow); text-transform: uppercase;
    }

    .vip-gold-line-main { width: 100px; height: 3px; background: linear-gradient(to right, var(--gold), transparent); margin-top: 10px; }
    .text-gold-gradient { background: linear-gradient(to bottom, var(--gold-bright), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-family: 'Cinzel', serif; }
    .vip-card-glow, .vip-card-black-glow { border: 1px solid rgba(212, 175, 55, 0.2); border-radius: 15px; }
    .vip-card-glow { background: #0a0a0a; }
    .vip-card-black-glow { background: #000; }
    .vip-label { color: var(--gold); font-size: 0.75rem; font-weight: bold; margin-bottom: 8px; display: block; }
    .vip-input { background: #000 !important; color: #fff !important; border: 1px solid #222 !important; }
    .btn-voegtoe { background: var(--gold); color: #000; font-weight: bold; border: none; border-radius: 8px; padding: 10px; transition: 0.3s; }
    .btn-push-small { background: var(--gold); color: #000; font-weight: bold; border: none; border-radius: 6px; padding: 6px 20px; font-size: 0.85rem; }
    .text-gold-var { color: var(--gold); }
    .vip-table tbody td { border-bottom: 1px solid rgba(212, 175, 55, 0.05); padding: 12px 10px; vertical-align: middle; }
</style>

<script>
    function showPublishFeedback(event, form) {
        event.preventDefault();
        const btn = document.getElementById('publishBtn');
        btn.innerHTML = '<i class="bi bi-check-lg"></i> GEPUBLICEERD';
        Swal.fire({
            title: 'ROOSTER GEPUBLICEERD',
            text: 'Alle medewerkers hebben een melding ontvangen.',
            icon: 'success',
            background: '#0a0a0a',
            color: '#D4AF37',
            confirmButtonColor: '#D4AF37'
        }).then(() => { form.submit(); });
    }

    function confirmDelete(id) {
        Swal.fire({
            title: 'VERWIJDEREN?',
            text: "Deze dienst wordt definitief gewist.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff4d4d',
            cancelButtonColor: '#333',
            confirmButtonText: 'JA, VERWIJDER',
            background: '#0a0a0a',
            color: '#fff'
        }).then((result) => { if (result.isConfirmed) { document.getElementById('delete-form-' + id).submit(); } });
    }
</script>