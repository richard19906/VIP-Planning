@{ Layout = "_Layout"; }
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:900;">📅 PLANNING OVERZICHT</h2>
        <button class="btn btn-gold" data-bs-toggle="modal" data-bs-target="#addPlan">➕ NIEUWE DIENST</button>
    </div>
    <div class="card p-0" style="background:rgba(10,10,10,0.9); border:2px solid #D4AF37; border-radius:20px; overflow:hidden;">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr><th>DATUM</th><th>MEDEWERKER</th><th>LOCATIE</th><th>UREN</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>25-04-2026</td>
                    <td>Richard Janssen</td>
                    <td>Main Event Hall</td>
                    <td>08:00 - 17:00</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addPlan" tabindex="-1">
    <div class="modal-dialog">
        <form action="/Home/SavePlanning" method="post" class="modal-content" style="background:#000; border:2px solid #D4AF37;">
            <div class="modal-header border-0"><h5 style="color:#D4AF37;">Nieuwe Planning Toevoegen</h5></div>
            <div class="modal-body">
                <input type="date" name="datum" class="form-control mb-3" required>
                <input type="text" name="medewerker" class="form-control mb-3" placeholder="Voor- en achternaam" required>
                <input type="text" name="locatie" class="form-control mb-3" placeholder="Locatie" required>
                <input type="text" name="uren" class="form-control mb-3" placeholder="Tijden (bijv. 09:00 - 18:00)" required>
                <button type="submit" class="btn btn-gold w-100">OPSLAAN IN SUPABASE</button>
            </div>
        </form>
    </div>
</div>