@model List<VIP_Planning.Models.PlanningModel>
@{
    Layout = "_Layout";
    var werknemers = (List<VIP_Planning.Models.ProfielModel>)ViewBag.Werknemers;
    var totaalUren = Model.Sum(x => (double)x.Uren);
}

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Inter:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --gold: #D4AF37;
        --gold-bright: #F9E27D;
        --glow: rgba(212, 175, 55, 0.4);
    }

    body { background-color: #000; color: #fff; font-family: 'Inter', sans-serif; }

    /* TITEL: IETS KLEINER GEMAAKT */
    .vip-title-container { margin-bottom: 30px; text-align: left; }
    .vip-title {
        font-family: 'Cinzel', serif;
        font-weight: 900;
        font-size: 2.2rem; /* Was 2.8rem */
        letter-spacing: 4px;
        background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 15px var(--glow);
        text-transform: uppercase;
        margin: 0;
    }
    .vip-title-line { width: 70px; height: 3px; background: var(--gold); margin-top: 8px; }

    /* TOTAAL UREN */
    .total-display { text-align: right; border-right: 3px solid var(--gold); padding-right: 15px; }
    .total-label { color: var(--gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; }
    .total-val { font-family: 'JetBrains Mono'; font-size: 1.5rem; font-weight: bold; }

    /* INPUTS */
    .vip-card { background: #0a0a0a; border: 1px solid #222; border-radius: 10px; padding: 20px; }
    .vip-label { color: var(--gold); font-size: 0.75rem; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; display: block; }
    .vip-input { 
        background: #000 !important; color: #fff !important; border: 1px solid #333 !important; 
        height: 45px; border-radius: 6px; -webkit-text-fill-color: #fff !important;
    }
    
    input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(68%) sepia(51%) saturate(546%) hue-rotate(5deg) brightness(93%) contrast(88%);
    }

    /* TABEL HEADER: GOUD MET ZWARTE TEKST */
    .vip-table-container { background: #000; border: 1px solid #222; border-radius: 10px; overflow: hidden; margin-top: 20px; }
    .table { margin: 0; border: none !important; }
    
    .table thead tr { 
        background: linear-gradient(to bottom, var(--gold-bright), var(--gold)) !important; 
    }
    .table thead th { 
        color: #000 !important; /* Zwarte tekst op gouden balk */
        padding: 15px; 
        border: none !important; 
        text-transform: uppercase; 
        font-size: 0.75rem; 
        font-weight: 900;
    }
    
    .table tbody td { 
        padding: 15px; 
        color: var(--gold-bright) !important; /* Ingevoerde tekst goud */
        background: transparent !important;
        border-bottom: 1px solid #111; 
    }

    .btn-vip { background: var(--gold); color: #000; font-weight: 900; border: none; height: 45px; border-radius: 6px; width: 100%; text-transform: uppercase; }
    .btn-icon { background: transparent; border: 1px solid #333; padding: 5px 8px; border-radius: 5px; color: var(--gold); }
</style>

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="vip-title-container">
            <h1 class="vip-title">Rooster Beheer</h1>
            <div class="vip-title-line"></div>
        </div>
        <div class="total-display">
            <span class="total-label">Totaal Uren</span>
            <div class="total-val">@totaalUren.ToString("N1")</div>
        </div>
    </div>

    <!-- INVOER -->
    <div class="vip-card mb-4">
        <form action="/Home/OpslaanLokaal" method="post" id="planningForm" class="row g-2 align-items-end">
            <input type="hidden" name="Id" id="mainId" value="0" />
            
            <div class="col-md-3">
                <label class="vip-label">Werknemer</label>
                <select name="UserEmail" id="mainEmail" class="form-select vip-input" required>
                    <option value="">KIES...</option>
                    @foreach (var w in werknemers) { <option value="@w.Email">@w.Naam.ToUpper()</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label class="vip-label">Datum</label>
                <input name="DatumString" id="mainDatum" type="date" class="form-control vip-input" required />
            </div>
            <div class="col-md-2">
                <label class="vip-label">Locatie</label>
                <input name="Locatie" id="mainLocatie" class="form-control vip-input" placeholder="LOCATIE" required />
            </div>
            <div class="col-md-1">
                <label class="vip-label">Van</label>
                <input name="StartTijd" id="mainStart" type="text" maxlength="5" placeholder="00:00" class="form-control vip-input time-calc" />
            </div>
            <div class="col-md-1">
                <label class="vip-label">Tot</label>
                <input name="EindTijd" id="mainEind" type="text" maxlength="5" placeholder="00:00" class="form-control vip-input time-calc" />
            </div>
            <div class="col-md-1">
                <label class="vip-label">Uren</label>
                <input name="Uren" id="mainUren" type="text" class="form-control vip-input text-center" />
            </div>
            <div class="col-md-2">
                <button type="submit" id="btnSubmit" class="btn-vip">OPSLAAN</button>
            </div>
        </form>
    </div>

    <!-- TABEL -->
    <div class="vip-table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Datum</th>
                    <th>Werknemer</th>
                    <th>Locatie</th>
                    <th class="text-center">Tijden</th>
                    <th class="text-center">Uren</th>
                    <th class="text-end">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@DateTime.Parse(item.Datum).ToString("dd-MM-yyyy")</td>
                        <td class="fw-bold">@item.UserNaam</td>
                        <td>@item.Locatie</td>
                        <td class="text-center">@item.StartTijd - @item.EindTijd</td>
                        <td class="text-center fw-bold">@item.Uren.ToString("N1")</td>
                        <td class="text-end">
                            <button class="btn-icon me-2" onclick="editDienst('@item.Id', '@item.UserEmail', '@item.Datum', '@item.Locatie', '@item.StartTijd', '@item.EindTijd', '@item.Uren')">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            @* Fix voor 405: Zorg dat Verwijderen een GET-link is *@
                            <a href="@Url.Action("Verwijderen", "Home", new { id = item.Id })" class="btn-icon" style="color:#ff4444;" onclick="return confirm('Verwijderen?')">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // TIJD CALCULATIE (VOORKOMT 90 FOUT)
    document.querySelectorAll('.time-calc').forEach(input => {
        input.addEventListener('input', function(e) {
            let val = e.target.value.replace(/\D/g, '');
            if (val.length >= 3) val = val.slice(0, 2) + ':' + val.slice(2, 4);
            e.target.value = val;
            
            const form = e.target.closest('form');
            const sVal = form.querySelector('[name="StartTijd"]').value;
            const eVal = form.querySelector('[name="EindTijd"]').value;
            
            if (sVal.length === 5 && eVal.length === 5) {
                const s = sVal.split(':');
                const e_parts = eVal.split(':');
                let diff = (parseInt(e_parts[0], 10) * 60 + parseInt(e_parts[1], 10)) - (parseInt(s[0], 10) * 60 + parseInt(s[1], 10));
                if (diff < 0) diff += 1440;
                form.querySelector('[name="Uren"]').value = (diff / 60).toFixed(1).replace('.', ',');
            }
        });
    });

    function editDienst(id, email, datum, loc, start, eind, uren) {
        document.getElementById('mainId').value = id;
        document.getElementById('mainEmail').value = email;
        document.getElementById('mainLocatie').value = loc;
        document.getElementById('mainStart').value = start;
        document.getElementById('mainEind').value = eind;
        document.getElementById('mainUren').value = parseFloat(uren.toString().replace(',', '.')).toFixed(1).replace('.', ',');
        if(datum) document.getElementById('mainDatum').value = new Date(datum).toISOString().split('T')[0];
        document.getElementById('btnSubmit').innerText = "BIJWERKEN";
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>