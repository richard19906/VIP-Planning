@model List<VIP_Planning.Models.ProfielModel>
@{ Layout = "_Layout"; }
<h2 class="mb-4" style="color:#D4AF37; font-weight:900;">👥 GEREGISTREERDE WERKNEMERS</h2>
<div class="row g-3">
    @foreach(var w in Model) {
        <div class="col-md-4">
            <div class="card p-3 bg-black border-warning text-center" style="border-radius:15px;">
                <h4 class="text-white">@w.Naam</h4>
                <p class="text-gold small">@w.Email</p>
                <a href="/Home/UrenOverzicht?email=@w.Email&naam=@w.Naam" class="btn btn-sm btn-gold" style="background:#D4AF37; color:#000; font-weight:bold;">BEKIJK UREN</a>
            </div>
        </div>
    }
</div>