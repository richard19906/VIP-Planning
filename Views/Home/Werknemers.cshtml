<!-- Google Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Inter:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@model List<VIP_Planning.Models.ProfielModel>
@{
    Layout = "_Layout";
}

<div class="container-fluid py-4 px-4">
    <!-- Header Sectie: Nu strak in de linkse hoek -->
    <div class="mb-5 text-start">
        <h2 class="vip-header-title-main">GEREGISTREERDE WERKNEMERS</h2>
        <div class="vip-gold-line-main"></div>
    </div>

    <!-- Werknemers Grid -->
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var w in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="vip-profile-card">
                        <div class="card-glow"></div>
                        <div class="card-content p-4 text-center">
                            <div class="avatar-circle mb-3 mx-auto">
                                <span class="avatar-initial">@(string.IsNullOrEmpty(w.Naam) ? "V" : w.Naam.Substring(0, 1).ToUpper())</span>
                            </div>
                            
                            <h4 class="text-white fw-bold mb-1 tracking-tight">@w.Naam?.ToUpper()</h4>
                            <p class="text-gold-muted small mb-4 font-monospace">@w.Email?.ToLower()</p>
                            
                            <hr class="border-gold-subtle mb-4">
                            
                            <a href="/Home/UrenOverzicht?email=@w.Email&naam=@w.Naam" class="btn-vip-outline w-100">
                                <i class="bi bi-file-earmark-bar-graph me-2"></i>BEKIJK UREN
                            </a>
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Beheer kaart -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a href="/Home/Instellingen" class="text-decoration-none h-100 d-block">
                <div class="vip-profile-card add-card d-flex align-items-center justify-content-center">
                    <div class="text-center">
                        <i class="bi bi-person-gear text-gold-muted display-5"></i>
                        <p class="text-gold-muted mt-2 fw-bold small tracking-widest">BEHEER WERKNEMERS</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    :root {
        --gold: #D4AF37; 
        --gold-bright: #F9E27D;
        --glow: rgba(212, 175, 55, 0.4); 
    }

    /* Pagina titel: Uitgelijnd naar links */
    .vip-header-title-main {
        font-family: 'Cinzel', serif;
        font-weight: 900;
        font-size: 2.2rem; /* Iets verkleind voor betere hoek-passing */
        letter-spacing: 4px;
        background: linear-gradient(to bottom, var(--gold-bright) 0%, var(--gold) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 15px var(--glow);
        margin: 0;
        text-transform: uppercase;
    }

    /* De gouden lijn onder de titel: Begint links en vervaagt naar rechts */
    .vip-gold-line-main {
        width: 200px;
        height: 3px;
        background: linear-gradient(to right, var(--gold), transparent);
        margin: 10px 0 0 0; /* Margin-left op 0 gezet */
        box-shadow: 0 0 10px var(--glow);
    }

    .vip-profile-card {
        background: linear-gradient(145deg, #121212, #080808);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 16px;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease-in-out;
        height: 100%;
    }

    .vip-profile-card:hover {
        transform: translateY(-8px);
        border-color: var(--gold);
        box-shadow: 0 12px 30px rgba(212, 175, 55, 0.2);
    }

    .avatar-circle {
        width: 64px; height: 64px;
        background: rgba(212, 175, 55, 0.05);
        border: 1px solid var(--gold);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 10px var(--glow);
    }

    .avatar-initial {
        color: var(--gold);
        font-size: 1.5rem; font-weight: 800;
        font-family: 'Cinzel', serif;
    }

    .btn-vip-outline {
        display: inline-block;
        background: transparent;
        border: 1px solid var(--gold);
        color: var(--gold);
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
        text-decoration: none;
    }

    .btn-vip-outline:hover {
        background: var(--gold);
        color: black;
        box-shadow: 0 0 20px var(--glow);
    }

    .text-gold-muted { color: #A88A2D; }
    .border-gold-subtle { border-color: rgba(212, 175, 55, 0.1) !important; }
    .add-card { border: 2px dashed rgba(212, 175, 55, 0.2); background: transparent; }
</style>