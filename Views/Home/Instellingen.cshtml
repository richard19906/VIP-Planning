@{ Layout = "_Layout"; }
<h1 style="font-weight:900; margin-bottom:30px;">SYSTEEM <span style="color:#D4AF37;">INSTELLINGEN</span></h1>

<div class="row">
    <div class="col-md-6">
        <div class="stat-card mb-4">
            <h5 style="color:#D4AF37;">Profiel Instellingen</h5>
            <hr style="border-color:#333;">
            <div class="mb-3"><label style="color:#888;">Admin Naam</label><input type="text" class="form-control bg-black border-secondary text-white" value="Admin User"></div>
            <div class="mb-3"><label style="color:#888;">E-mail</label><input type="email" class="form-control bg-black border-secondary text-white" value="admin@vip.nl"></div>
            <button class="btn btn-outline-warning w-100">Opslaan</button>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card">
            <h5 style="color:#D4AF37;">Database & API</h5>
            <hr style="border-color:#333;">
            <p style="color:#888; font-size:0.8rem;">Supabase Status: <span class="text-success">Verbonden</span></p>
            <div class="mb-3"><label style="color:#888;">API Sleutel</label><input type="password" class="form-control bg-black border-secondary text-white" value="******************"></div>
            <button class="btn btn-outline-secondary w-100">Verbinding Testen</button>
        </div>
    </div>
</div>