@{ Layout = "_Layout"; }
<div class="container-fluid mt-2">
    <h1 style="font-weight:900; letter-spacing:2px; margin-bottom:30px;">⚙️ INSTELLINGEN & BEHEER</h1>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(10,10,10,0.9); border: 2px solid #D4AF37; border-radius: 20px;">
                <h3 style="margin-bottom:20px;">🔐 Pincode</h3>
                <form action="/Home/SavePincode" method="post">
                    <label>Nieuwe 4-cijferige Code</label>
                    <input type="password" name="newPin" class="form-control text-center mb-3" placeholder="****" maxlength="4" style="font-size:1.5rem; letter-spacing:10px;">
                    <button type="submit" class="btn btn-gold w-100">PINCODE OPSLAAN</button>
                </form>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(10,10,10,0.9); border: 2px solid #D4AF37; border-radius: 20px;">
                <h3 style="margin-bottom:20px;">🔑 Wachtwoord</h3>
                <form action="/Home/UpdatePassword" method="post">
                    <label>Huidig Wachtwoord</label>
                    <input type="password" name="oldPw" class="form-control mb-2" placeholder="******">
                    <label>Nieuw Wachtwoord</label>
                    <input type="password" name="newPw" class="form-control mb-3" placeholder="******">
                    <button type="submit" class="btn btn-gold w-100">WACHTWOORD UPDATEN</button>
                </form>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(10,10,10,0.9); border: 2px solid #D4AF37; border-radius: 20px;">
                <h3 style="margin-bottom:20px;">💻 Systeem Status</h3>
                <div class="p-2 mb-2 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(212,175,55,0.2);">
                    <span>DATABASE</span>
                    <div style="width:10px; height:10px; background:#28a745; border-radius:50%; box-shadow:0 0 10px #28a745;"></div>
                </div>
                <div class="p-2 mb-2 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(212,175,55,0.2);">
                    <span>PDF ENGINE</span>
                    <span style="color:#fff !important;">ACTIEF</span>
                </div>
                <div class="p-2">
                    <span style="display:block; font-size:0.8rem;">SOFTWARE VERSIE</span>
                    <span class="badge bg-warning text-dark mt-1">2.3.2504-0506 (VIP Elite)</span>
                    <small style="display:block; margin-top:5px; color:#fff !important;">Push: 05:06 25-04</small>
                </div>
            </div>
        </div>
    </div>
</div>