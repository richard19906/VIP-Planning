@{ Layout = "_Layout"; }
<div class="container-fluid mt-2">
    <h1 style="font-weight:900; letter-spacing:2px; margin-bottom:40px; text-transform: uppercase;">⚙️ Instellingen & Beheer</h1>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(10,10,10,0.9); border: 2px solid #D4AF37; border-radius: 25px; box-shadow: 0 0 20px rgba(212,175,55,0.1);">
                <h3 style="margin-bottom:25px; border-bottom: 1px solid rgba(212,175,55,0.3); padding-bottom:10px;">🔐 Pincode Beheer</h3>
                <form action="/Home/SavePincode" method="post">
                    <label style="display:block; margin-bottom:10px;">Nieuwe 4-cijferige Bypass</label>
                    <input type="password" name="newPin" class="form-control text-center mb-4" placeholder="****" maxlength="4" style="font-size:2rem; letter-spacing:15px; height:70px;">
                    <button type="submit" class="btn btn-gold w-100 py-3">BEWAREN</button>
                </form>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(10,10,10,0.9); border: 2px solid #D4AF37; border-radius: 25px; box-shadow: 0 0 20px rgba(212,175,55,0.1);">
                <h3 style="margin-bottom:25px; border-bottom: 1px solid rgba(212,175,55,0.3); padding-bottom:10px;">🔑 Account Beveiliging</h3>
                <form action="/Home/UpdatePassword" method="post">
                    <label>Huidig Wachtwoord</label>
                    <input type="password" name="oldPw" class="form-control mb-3" placeholder="******">
                    <label>Nieuw Wachtwoord</label>
                    <input type="password" name="newPw" class="form-control mb-4" placeholder="******">
                    <button type="submit" class="btn btn-gold w-100 py-3">WIJZIGEN</button>
                </form>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 h-100" style="background: rgba(10,10,10,0.9); border: 2px solid #D4AF37; border-radius: 25px; box-shadow: 0 0 20px rgba(212,175,55,0.1);">
                <h3 style="margin-bottom:25px; border-bottom: 1px solid rgba(212,175,55,0.3); padding-bottom:10px;">💻 Systeem Status</h3>
                <div class="py-3 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(212,175,55,0.1);">
                    <span style="font-weight:bold;">DATABASE STATUS</span>
                    <div class="d-flex align-items-center">
                        <span style="color:#28a745 !important; font-size:0.8rem; margin-right:8px;">ONLINE</span>
                        <div style="width:12px; height:12px; background:#28a745; border-radius:50%; box-shadow:0 0 10px #28a745;"></div>
                    </div>
                </div>
                <div class="py-3 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid rgba(212,175,55,0.1);">
                    <span style="font-weight:bold;">PDF CLOUD</span>
                    <span style="color:#ffffff !important;">CONNECTED</span>
                </div>
                <div class="mt-4">
                    <span style="font-size:0.7rem; letter-spacing:1px; display:block; margin-bottom:5px;">BUILD VERSION</span>
                    <div style="background:#D4AF37; color:#000; padding:10px; border-radius:10px; font-weight:900; text-align:center;">2.4.2504-0507 (VIP Elite)</div>
                    <small style="display:block; text-align:center; margin-top:10px; color:#ffffff !important;">Synchronisatie: 05:07 25-04</small>
                </div>
            </div>
        </div>
    </div>
</div>