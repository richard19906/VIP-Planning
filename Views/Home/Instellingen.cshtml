@{ Layout = "_Layout"; }
<div class="container mt-5">
    <h2 style="color:#D4AF37; font-weight:900; letter-spacing:2px;">⚙️ Instellingen & Beheer</h2>
    <hr style="border-color:#D4AF37;">
    
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="p-4" style="background: rgba(10,10,10,0.8); border: 2px solid #D4AF37; border-radius: 20px;">
                <h4 style="color:#D4AF37; margin-bottom:20px;">Toegangscode (Pincode)</h4>
                <p class="small text-white-50">Stel hier een 4-cijferige pincode in voor de snelle admin-bypass op het inlogscherm.</p>
                <form action="/Home/SavePincode" method="post">
                    <input type="password" name="newPin" class="form-control mb-3 text-center" placeholder="Nieuwe 4-cijferige pincode" maxlength="4" style="background:rgba(255,255,255,0.05); border:1px solid #D4AF37; color:#fff; font-size:1.5rem;">
                    <button type="submit" class="btn w-100" style="background:#D4AF37; color:#000; font-weight:bold;">PINCODE OPSLAAN</button>
                </form>
            </div>
        </div>
    </div>
</div>