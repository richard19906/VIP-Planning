@{ Layout = "_Layout"; }
<div class="container-fluid">
    <h1 style="color:#D4AF37; font-weight:900; text-transform:uppercase;">⚙️ Instellingen</h1>
    <div style="background:#0f0f0f; border:1px solid #D4AF37; border-radius:20px; padding:30px; margin-top:20px;">
        <h4 class="text-white">Systeembeheer</h4>
        <p class="text-secondary">Beheer hier de applicatie-instellingen en je account.</p>
